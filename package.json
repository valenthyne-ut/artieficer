{
  "name": "artieficer",
  "version": "0.1.1",
  "description": "A platform written in Typescript to manage and/or run multiple Discord bots at once.",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rm -rf ./dist && tsc --build tsconfig.json",
    "postbuild": "cpy 'src/**/.cfg.json' dist/",
    "start": "node ./dist/index.js",
    "buildrun": "npm run build && npm start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valenthyne-ut/Artieficer.git"
  },
  "author": "valenthyne-ut",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/valenthyne-ut/Artieficer/issues"
  },
  "homepage": "https://github.com/valenthyne-ut/Artieficer#readme",
  "dependencies": {
    "@types/node": "^20.9.1",
    "chalk": "^4.1.2",
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "cpy-cli": "^5.0.0",
    "eslint": "^8.52.0",
    "tsc-hooks": "^1.1.2"
  }
}
